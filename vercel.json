{
  "version": 2,
  "public": true,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/training", "destination": "/training.html" },
    { "source": "/functions", "destination": "/functions.html" },
    { "source": "/laws", "destination": "/laws.html" },
    { "source": "/tools", "destination": "/tools.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/architecture", "destination": "/architecture.html" },
    { "source": "/use-cases", "destination": "/use-cases.html" }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "header", "key": "x-forwarded-proto", "value": "http" }],
      "destination": "https://telecom.vaitechpro.com/:path*",
      "permanent": true
    }
  ]
}
