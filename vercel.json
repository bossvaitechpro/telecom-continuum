{
  "version": 2,
  "public": true,
  "github": {
    "enabled": false
  },
  "builds": [
    {
      "src": "dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/training", "dest": "/training.html" },
    { "src": "/functions", "dest": "/functions.html" },
    { "src": "/laws", "dest": "/laws.html" },
    { "src": "/tools", "dest": "/tools.html" },
    { "src": "/about", "dest": "/about.html" },
    { "src": "/architecture", "dest": "/architecture.html" },
    { "src": "/use-cases", "dest": "/use-cases.html" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/$1.html" }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "header", "key": "x-forwarded-proto", "value": "http" }],
      "destination": "https://telecom.vaitechpro.com/:path*",
      "permanent": true
    }
  ]
}
