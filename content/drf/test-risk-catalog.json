  "instrument_mapping": {
    "evolver": {
      "role": "Active protocol testing - executes all YAML scenarios",
      "tier_coverage": "All tiers",
      "value_proposition": "Prove DRF transforms GTP correctly before deployment",
      "automation_readiness": "YAML files ready for batch execution"
    },
    "nscan": {
      "role": "Passive traffic validation - captures live DRF traffic",
      "tier_coverage": "Tier 1 + critical Tier 2",
      "value_proposition": "Prove real subscriber traffic transforms correctly in production",
      "focus": "TEID aliasing verification, CDR correlation"
    },
    "ants": {
      "role": "End-to-end field validation from roaming locations",
      "tier_coverage": "Tier 1 only",
      "value_proposition": "Prove roaming works for real subscribers in target markets",
      "deployment_context": "Senegal and other field locations"
    }
  },
  "key_metrics": {
    "drf_health_score": {
      "formula": "(Tier_1_Pass / Tier_1_Total) * 40 + (Tier_2_Pass / Tier_2_Total) * 35 + (Tier_3_Pass / Tier_3_Total) * 25",
      "target": ">= 95",
      "calculation_frequency": "Hourly"
    },
    "revenue_at_risk": {
      "formula": "Count of Tier_1 failures * average_session_value",
      "alert_threshold": "> 0"
    },
    "cdr_completeness": {
      "formula": "CDRs_generated / Sessions_created",
      "target": "= 1.00",
      "verified_by": "Evolver CDR assertions + nScan capture + ANTS field"
    }
  }
